# DeepSeek API
DEEPSEEK_API_KEY=your_deepseek_api_key

# Database (Unified Adapter)
# DB_TYPE: mysql / postgresql / starrocks
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=your_database

# [Legacy] StarRocks specific (if DB_TYPE=starrocks, use DB_* above)
# STARROCKS_HOST=your-starrocks-host
# STARROCKS_PORT=9030
# STARROCKS_PASSWORD=your_password

# PostgreSQL (Experience Store)
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=agent_experience
PG_USER=agent_user
PG_PASSWORD=your_pg_password

# DingTalk Bot (replaceable with Slack/Teams)
DINGTALK_BOT_APP_KEY=your_app_key
DINGTALK_BOT_APP_SECRET=your_app_secret

# Optional
LOG_DIR=./logs
CHROMA_DIR=./chroma_db
